# Stars of David — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── DATABASE ───────────────────────────────────────────────
# PostgreSQL connection string.
# Local example:  postgresql://postgres:password@localhost:5432/starsofdavid
# Railway/Render: use the DATABASE_URL provided by the platform.
DATABASE_URL=postgresql://user:password@localhost:5432/starsofdavid

# ── PAYMENTS KILL SWITCH ───────────────────────────────────
# Set to "false" to take the site live for browsing/search while
# keeping checkout disabled — useful while nonprofit registration
# and Stripe account activation are still in progress.
# Set to "true" (or remove) once ready to accept real donations.
PAYMENTS_ENABLED=false

# ── SERVER ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the frontend (used for CORS and Stripe redirect URLs).
FRONTEND_URL=http://localhost:3000

# ── STRIPE ─────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Webhook signing secret — generated when you create the webhook in Stripe.
# For local development, use the Stripe CLI:
#   stripe listen --forward-to localhost:3001/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── CERTIFICATE STORAGE (Cloudflare R2) ───────────────────
# Optional in development — if unset, certificates save to
# public/certificates/ locally and serve from the API itself.
# For production, create a free R2 bucket at dash.cloudflare.com.
# R2 has no egress fees, which matters for a donation-funded project.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=starsofdavid-certificates
R2_PUBLIC_URL=https://cdn.stars-of-david.org

# ── EMAIL (Resend) ─────────────────────────────────────────
# Optional in development — if unset, certificate emails are
# logged to the console instead of sent.
# Get a free API key at resend.com.
RESEND_API_KEY=
EMAIL_FROM=Stars of David <dedications@stars-of-david.org>

# Used by storage.js to build local certificate URLs in dev.
BACKEND_URL=http://localhost:3001

# ── FRONTEND (public, injected into the page) ─────────────
# Used by public/js/donate.js to know where to call the API.
# Set this as a global before donate.js loads:
#   <script>window.STARS_API_URL = "https://api.stars-of-david.org";</script>
#   <script src="/js/donate.js"></script>
